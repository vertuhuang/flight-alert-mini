.picker {
  width: 100%;
}

/* Trigger */
.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  box-sizing: border-box;
}

.picker-trigger__content {
  flex: 1;
  min-width: 0;
}

.picker-trigger__label {
  font-size: 22rpx;
  color: #888888;
  line-height: 1.4;
}

.picker-trigger__value {
  font-size: 28rpx;
  color: #0f172a;
  line-height: 1.5;
}

.picker-trigger__placeholder {
  color: #888888;
}

.picker-trigger__arrow {
  font-size: 24rpx;
  color: #888888;
  margin-left: 16rpx;
}

/* Popup */
.picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.25s, visibility 0.25s;
}

.picker-popup--show {
  visibility: visible;
  opacity: 1;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.picker-popup--show .picker-panel {
  transform: translateY(0);
}

/* Header */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
  flex-shrink: 0;
}

.picker-header__cancel,
.picker-header__confirm {
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

.picker-header__cancel {
  color: #888888;
}

.picker-header__confirm {
  color: #2563eb;
  font-weight: 600;
}

.picker-header__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

/* Search */
.picker-search {
  padding: 16rpx 32rpx;
  flex-shrink: 0;
}

.picker-search__input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 36rpx;
  background: #f5f5f5;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* Body */
.picker-body {
  flex: 1;
  display: flex;
  min-height: 0;
  overflow: hidden;
}

/* List */
.picker-list {
  flex: 1;
  height: 55vh;
}

.picker-group__header {
  position: sticky;
  top: 0;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #888888;
  background: #f5f5f5;
  z-index: 1;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.picker-item--selected {
  background: #f5f5f5;
}

.picker-item__main {
  flex: 1;
  min-width: 0;
}

.picker-item__city {
  font-size: 30rpx;
  color: #0f172a;
  margin-right: 12rpx;
}

.picker-item__code {
  font-size: 24rpx;
  color: #888888;
}

.picker-item__airports {
  font-size: 22rpx;
  color: #888888;
  margin-left: 16rpx;
  white-space: nowrap;
}

.picker-item__check {
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 700;
  margin-left: 12rpx;
}

.picker-empty {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #888888;
}

/* Sidebar */
.picker-sidebar {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 4rpx;
  width: 56rpx;
  flex-shrink: 0;
}

.picker-sidebar__item {
  font-size: 20rpx;
  color: #888888;
  line-height: 1.6;
  padding: 2rpx 0;
  text-align: center;
}

.picker-sidebar__item--active {
  color: #333333;
  font-weight: 700;
  font-size: 22rpx;
}
