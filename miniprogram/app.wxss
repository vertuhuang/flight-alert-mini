page {
  background: #f8fafc;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.muted {
  color: #64748b;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.chip--green {
  background: #dcfce7;
  color: #166534;
}

.chip--gray {
  background: #e2e8f0;
  color: #334155;
}

.button-primary {
  background: linear-gradient(135deg, #2563eb, #0f172a);
  color: #ffffff;
  border-radius: 22rpx;
}

.button-secondary {
  background: #e2e8f0;
  color: #0f172a;
  border-radius: 22rpx;
}

.button-danger {
  background: #ef4444;
  color: #ffffff;
  border-radius: 22rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field__label {
  font-size: 24rpx;
  color: #334155;
  margin-bottom: 10rpx;
}

.field__input,
.field__picker,
.field__textarea {
  width: 100%;
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  box-sizing: border-box;
}

.field__textarea {
  min-height: 180rpx;
  padding-top: 24rpx;
}

.spacer-16 {
  height: 16rpx;
}

.spacer-24 {
  height: 24rpx;
}
