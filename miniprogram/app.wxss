@import './miniprogram_npm/tdesign-miniprogram/common/style/theme/_index.wxss';

page {
  background: #f5f6f9;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* Card */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

/* Section */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: -12rpx;
  margin-bottom: 20rpx;
}

/* Muted text */
.muted {
  color: #94a3b8;
  font-size: 24rpx;
}

/* Route display */
.route-display {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.route-arrow {
  color: #2563eb;
  margin: 0 12rpx;
}

/* Price highlight */
.price-highlight {
  font-size: 40rpx;
  font-weight: 800;
  color: #ef4444;
}

.price-label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 4rpx;
}

.price-unit {
  font-size: 24rpx;
  font-weight: 400;
  color: #94a3b8;
}

/* Info row */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.info-label {
  color: #94a3b8;
  font-size: 24rpx;
}

.info-value {
  color: #334155;
  font-size: 24rpx;
  font-weight: 500;
}

/* Divider */
.divider {
  height: 2rpx;
  background: #f1f5f9;
  margin: 20rpx 0;
}

/* Action row */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-row .t-button {
  flex: 1;
}

/* Spacer */
.spacer {
  height: 20rpx;
}

/* Empty state */
.empty-hint {
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
  padding: 60rpx 0;
}

/* Change item */
.change-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.change-label {
  font-size: 26rpx;
  color: #334155;
}

.change-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.change-badge--drop {
  background: #fef2f2;
  color: #dc2626;
}

.change-badge--rise {
  background: #f0fdf4;
  color: #16a34a;
}

.change-badge--initial {
  background: #f1f5f9;
  color: #64748b;
}

.history-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.history-item:last-child {
  border-bottom: none;
}
