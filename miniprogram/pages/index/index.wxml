<view class="page">
  <!-- Task list -->
  <block wx:if="{{tasks.length}}">
    <block wx:for="{{tasks}}" wx:key="id">
      <view class="card" data-id="{{item.id}}" bindtap="openTaskDetail">
        <!-- Title row -->
        <view style="display: flex; align-items: center; justify-content: space-between;">
          <view style="font-size: 30rpx; font-weight: 700; color: #0f172a;">{{item.name}}</view>
          <view style="display: flex; align-items: center; gap: 12rpx;">
            <t-badge wx:if="{{item.unreadEvents}}" count="{{item.unreadEvents}}" size="small" />
            <t-tag theme="{{item.active ? 'primary' : 'default'}}" variant="light" size="small">
              {{item.active ? '监控中' : '已暂停'}}
            </t-tag>
          </view>
        </view>

        <!-- Price -->
        <view wx:if="{{item.latestSummary && item.latestSummary.minPrice}}" style="margin-top: 12rpx;">
          <view class="price-label">当前最低价</view>
          <view class="price-highlight">{{item.latestSummary.minPrice}}<text class="price-unit">元</text></view>
        </view>

        <!-- Meta -->
        <view class="divider"></view>
        <view class="info-row">
          <text class="info-label">{{item.flightWay === 'Roundtrip' ? '往返' : '单程'}}</text>
          <text class="info-value">阈值 {{item.threshold}} 元</text>
        </view>
        <view class="info-row" wx:if="{{item.targetPrice}}">
          <text class="info-label">目标价</text>
          <text class="info-value">{{item.targetPrice}} 元</text>
        </view>
        <view class="info-row">
          <text class="info-label">上次检查</text>
          <text class="info-value">{{item.lastCheckedText || '尚未检查'}}</text>
        </view>
        <view wx:if="{{item.lastError}}" style="margin-top: 8rpx; color: #dc2626; font-size: 24rpx;">
          错误：{{item.lastError}}
        </view>
      </view>
    </block>
  </block>

  <!-- Empty state -->
  <view wx:else class="card">
    <t-empty icon="flight" description="还没有监控任务" />
    <view style="text-align: center; margin-top: 16rpx;">
      <t-button theme="primary" size="small" icon="add" bind:tap="goCreateTask">创建第一个任务</t-button>
    </view>
  </view>

  <!-- FAB -->
  <t-fab icon="add" bind:click="goCreateTask" />
</view>
