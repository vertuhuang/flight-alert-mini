<view class="page">
  <!-- Task list -->
  <block wx:if="{{tasks.length}}">
    <block wx:for="{{tasks}}" wx:key="id">
      <view class="card" data-id="{{item.id}}" bindtap="openTaskDetail">
        <!-- Route + Status -->
        <view style="display: flex; align-items: center; justify-content: space-between;">
          <view style="font-size: 32rpx; font-weight: 700; color: #0f172a;">{{item.routeText}}</view>
          <t-tag theme="{{item.active ? 'primary' : 'default'}}" variant="light" size="small">
            {{item.active ? '监控中' : '已暂停'}}
          </t-tag>
        </view>

        <!-- Dates -->
        <view style="margin-top: 8rpx; font-size: 26rpx; color: #64748b;">
          {{item.departDatesText}}
          <text wx:if="{{item.flightWay === 'Roundtrip'}}"> 往返</text>
          <text wx:else> 单程</text>
        </view>

        <!-- Price -->
        <view wx:if="{{item.latestSummary && item.latestSummary.minPrice}}" style="margin-top: 16rpx;">
          <view class="price-label">当前价格</view>
          <view class="price-highlight">{{item.latestSummary.minPrice}}<text class="price-unit">元</text></view>
        </view>

        <!-- Last price change -->
        <view style="margin-top: 12rpx; font-size: 24rpx; color: #94a3b8;">
          上次变价 {{item.lastPriceChangeText || '尚未变价'}}
        </view>

        <view wx:if="{{item.lastError}}" style="margin-top: 8rpx; color: #dc2626; font-size: 24rpx;">
          错误：{{item.lastError}}
        </view>
      </view>
    </block>
  </block>

  <!-- Empty state -->
  <view wx:else class="card">
    <t-empty icon="flight" description="还没有监控任务" />
    <view style="text-align: center; margin-top: 16rpx;">
      <t-button theme="primary" size="small" icon="add" bind:tap="goCreateTask">创建第一个任务</t-button>
    </view>
  </view>

  <!-- FAB -->
  <t-fab icon="add" bind:click="goCreateTask" />
</view>
