.field-label {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.date-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.date-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.date-tag--add {
  background: #eff6ff;
  color: #2563eb;
  border: 1rpx dashed #2563eb;
}

.date-tag__remove {
  color: #94a3b8;
  font-size: 22rpx;
  padding: 4rpx;
}

/* TDesign 组件样式调整 */
.custom-cell {
  padding-left: 32rpx !important;
  padding-right: 16rpx !important;
}

.custom-cell .t-cell__right-icon {
  font-size: 28rpx !important;
}

.custom-input {
  padding-left: 32rpx !important;
  padding-right: 32rpx !important;
}

.custom-textarea {
  padding-left: 32rpx !important;
  padding-right: 32rpx !important;
}

.form-list {
  margin-left: -32rpx;
  margin-right: -32rpx;
  margin-bottom: -32rpx;
  overflow: hidden;
  border-radius: 0 0 24rpx 24rpx;
}
