.field-label {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.date-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.date-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.date-tag--add {
  background: #eff6ff;
  color: #2563eb;
  border: 1rpx dashed #2563eb;
}

.date-tag__remove {
  color: #94a3b8;
  font-size: 22rpx;
  padding: 4rpx;
}
