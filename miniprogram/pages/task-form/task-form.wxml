<view class="page">
  <view class="card">
    <!-- Route -->
    <view style="margin-top: 24rpx;">
      <view class="field-label">出发城市</view>
      <airport-picker
        label="出发城市"
        placeholder="选择出发城市"
        value="{{form.placeFrom}}"
        bind:change="onFromChange"
      />
    </view>

    <view style="margin-top: 16rpx;">
      <view class="field-label">到达城市</view>
      <airport-picker
        label="到达城市"
        placeholder="选择到达城市"
        value="{{form.placeTo}}"
        bind:change="onToChange"
      />
    </view>

    <!-- Flight way -->
    <view style="margin-top: 24rpx;">
      <t-picker
        title="航程类型"
        value="{{flightWayIndex}}"
        options="{{flightWayOptions}}"
        bind:confirm="onFlightWayConfirm"
      >
        <t-cell title="航程类型" note="{{flightWayLabels[flightWayIndex]}}" arrow />
      </t-picker>
    </view>

    <!-- Dates -->
    <view style="margin-top: 24rpx;">
      <view class="field-label">出发日期</view>
      <view class="date-tags">
        <view wx:for="{{departDateTags}}" wx:key="code" class="date-tag">
          <text>{{item.label}}</text>
          <text class="date-tag__remove" data-code="{{item.code}}" bindtap="removeDepartDate">✕</text>
        </view>
        <view class="date-tag date-tag--add" bindtap="openDepartDatePicker">
          <text>+ 添加</text>
        </view>
      </view>
    </view>

    <view wx:if="{{flightWayIndex === 1}}" style="margin-top: 16rpx;">
      <view class="field-label">返程日期</view>
      <view class="date-tags">
        <view wx:for="{{returnDateTags}}" wx:key="code" class="date-tag">
          <text>{{item.label}}</text>
          <text class="date-tag__remove" data-code="{{item.code}}" bindtap="removeReturnDate">✕</text>
        </view>
        <view class="date-tag date-tag--add" bindtap="openReturnDatePicker">
          <text>+ 添加</text>
        </view>
      </view>
    </view>

    <!-- Date Pickers -->
    <t-date-time-picker
      visible="{{showDepartDatePicker}}"
      mode="date"
      title="选择出发日期"
      value="{{datePickerValue}}"
      bind:pick="onDepartDatePick"
      bind:confirm="confirmDepartDate"
      bind:cancel="cancelDepartDatePicker"
    />

    <t-date-time-picker
      visible="{{showReturnDatePicker}}"
      mode="date"
      title="选择返程日期"
      value="{{datePickerValue}}"
      bind:pick="onReturnDatePick"
      bind:confirm="confirmReturnDate"
      bind:cancel="cancelReturnDatePicker"
    />
  </view>

  <!-- Monitor strategy -->
  <view class="card">
    <view class="section-title">监控策略</view>

    <view style="margin-left: -32rpx; margin-right: -32rpx;">
      <t-input
        label="变动阈值"
        placeholder="价格变动多少元时通知"
        type="number"
        value="{{form.threshold}}"
        bind:change="onInputChange"
        data-field="threshold"
        suffix="元"
      />

      <t-input
        label="目标价格"
        placeholder="低于此价格时通知（可选）"
        type="number"
        value="{{form.targetPrice}}"
        bind:change="onInputChange"
        data-field="targetPrice"
        suffix="元"
      />

      <t-input
        label="检查间隔"
        placeholder="多久检查一次价格"
        type="number"
        value="{{form.checkIntervalSec}}"
        bind:change="onInputChange"
        data-field="checkIntervalSec"
        suffix="秒"
      />

      <t-cell title="仅降价时通知" bordered="{{false}}">
        <t-switch
          slot="note"
          value="{{form.notifyOnDrop}}"
          bind:change="onNotifyDropChange"
        />
      </t-cell>
    </view>
  </view>

  <!-- Notification -->
  <view class="card">
    <view class="section-title">通知方式</view>
    <view class="section-desc">配置 PushPlus Token 后，价格变动会推送到微信</view>

    <view style="margin-left: -32rpx; margin-right: -32rpx;">
      <t-textarea
        placeholder="PushPlus Token（不填则仅在小程序内记录）"
        value="{{form.pushplusToken}}"
        bind:change="onInputChange"
        data-field="pushplusToken"
        maxlength="{{200}}"
        autosize
      />

      <t-cell title="创建后立即启用" bordered="{{false}}">
        <t-switch
          slot="note"
          value="{{form.active}}"
          bind:change="onActiveChange"
        />
      </t-cell>
    </view>
  </view>

  <!-- Submit -->
  <view style="margin-top: 32rpx; padding-bottom: 40rpx;">
    <t-button
      theme="primary"
      size="large"
      block
      loading="{{submitting}}"
      bind:tap="submit"
    >
      {{isEdit ? '更新任务' : '创建任务'}}
    </t-button>
  </view>
</view>
