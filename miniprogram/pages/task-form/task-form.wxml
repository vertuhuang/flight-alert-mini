<view class="page">
  <view class="card">
    <view class="section-title">任务配置</view>

    <view class="field">
      <view class="field__label">任务名称</view>
      <input class="field__input" placeholder="例如：济南飞昆明五一单程" data-field="name" value="{{form.name}}" bindinput="onInput" />
    </view>

    <view class="field">
      <view class="field__label">出发机场代码</view>
      <input class="field__input" placeholder="例如 TNA" maxlength="3" data-field="placeFrom" value="{{form.placeFrom}}" bindinput="onInput" />
    </view>

    <view class="field">
      <view class="field__label">到达机场代码</view>
      <input class="field__input" placeholder="例如 KMG" maxlength="3" data-field="placeTo" value="{{form.placeTo}}" bindinput="onInput" />
    </view>

    <view class="field">
      <view class="field__label">航程类型</view>
      <picker class="field__picker" mode="selector" range="{{flightWays}}" value="{{flightWayIndex}}" bindchange="onFlightWayChange">
        <view style="line-height: 84rpx; padding: 0 24rpx;">{{flightWays[flightWayIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field__label">出发日期</view>
      <textarea class="field__textarea" placeholder="多个日期用逗号分隔，格式 YYYYMMDD" data-field="departDates" value="{{form.departDates}}" bindinput="onInput" />
    </view>

    <view wx:if="{{flightWays[flightWayIndex] === 'Roundtrip'}}" class="field">
      <view class="field__label">返程日期</view>
      <textarea class="field__textarea" placeholder="多个日期用逗号分隔，格式 YYYYMMDD" data-field="returnDates" value="{{form.returnDates}}" bindinput="onInput" />
    </view>

    <view class="field">
      <view class="field__label">价格变动阈值（元）</view>
      <input class="field__input" type="number" data-field="threshold" value="{{form.threshold}}" bindinput="onInput" />
    </view>

    <view class="field">
      <view class="field__label">检查间隔（秒）</view>
      <input class="field__input" type="number" data-field="checkIntervalSec" value="{{form.checkIntervalSec}}" bindinput="onInput" />
    </view>

    <view class="field">
      <view class="field__label">PushPlus Token</view>
      <textarea class="field__textarea" placeholder="不填则只记录事件，不推送微信消息" data-field="pushplusToken" value="{{form.pushplusToken}}" bindinput="onInput" />
    </view>

    <view class="field">
      <view class="row">
        <view class="field__label" style="margin-bottom: 0;">创建后立即启用</view>
        <switch checked="{{form.active}}" bindchange="onActiveChange" />
      </view>
    </view>

    <button class="button-primary" loading="{{submitting}}" bindtap="submit">保存任务</button>
  </view>
</view>
