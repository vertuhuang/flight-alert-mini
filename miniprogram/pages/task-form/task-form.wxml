<view class="page">
  <view class="card">
    <view class="section-title">航线信息</view>

    <view class="form-list">
      <t-cell title="出发城市" arrow bindtap="openFromPicker" t-class="custom-cell">
        <text slot="note" style="color: {{form.placeFrom ? '#0f172a' : 'rgba(0, 0, 0, 0.4)'}};">{{form.placeFrom ? placeFromText : '请选择'}}</text>
      </t-cell>
      <airport-picker id="fromPicker" show-trigger="{{false}}" label="选择出发城市" placeholder="请选择出发城市" value="{{form.placeFrom}}" bind:change="onFromChange" />

      <t-cell title="到达城市" arrow bindtap="openToPicker" t-class="custom-cell">
        <text slot="note" style="color: {{form.placeTo ? '#0f172a' : 'rgba(0, 0, 0, 0.4)'}};">{{form.placeTo ? placeToText : '请选择'}}</text>
      </t-cell>
      <airport-picker id="toPicker" show-trigger="{{false}}" label="选择到达城市" placeholder="请选择到达城市" value="{{form.placeTo}}" bind:change="onToChange" />

      <t-cell title="航程类型" arrow bindtap="openFlightWayPicker" t-class="custom-cell">
        <text slot="note" style="color: #0f172a;">{{flightWayLabels[flightWayIndex]}}</text>
      </t-cell>
      <t-picker title="选择航程类型" visible="{{showFlightWayPicker}}" value="{{[flightWayValue]}}" bind:confirm="onFlightWayConfirm" bind:cancel="onFlightWayCancel">
        <t-picker-item options="{{flightWayOptions[0]}}"></t-picker-item>
      </t-picker>

      <t-cell title="出发日期" arrow bindtap="openDepartDatePicker" t-class="custom-cell">
        <text slot="note" style="color: {{departDateLabel ? '#0f172a' : 'rgba(0, 0, 0, 0.4)'}};">{{departDateLabel || '请选择'}}</text>
      </t-cell>
      <t-date-time-picker wx:if="{{showDepartDatePicker}}" visible="{{showDepartDatePicker}}" mode="date" title="选择出发日期" value="{{departDateValue}}" bind:confirm="onDepartDateConfirm" bind:cancel="onDepartDateCancel" />

      <t-cell wx:if="{{flightWayIndex === 1}}" title="返程日期" arrow bindtap="openReturnDatePicker" t-class="custom-cell">
        <text slot="note" style="color: {{returnDateLabel ? '#0f172a' : 'rgba(0, 0, 0, 0.4)'}};">{{returnDateLabel || '请选择'}}</text>
      </t-cell>
      <t-date-time-picker wx:if="{{flightWayIndex === 1 && showReturnDatePicker}}" visible="{{showReturnDatePicker}}" mode="date" title="选择返程日期" value="{{returnDateValue}}" bind:confirm="onReturnDateConfirm" bind:cancel="onReturnDateCancel" />
    </view>
  </view>

  <!-- Monitor strategy -->
  <view class="card">
    <view class="section-title">监控策略</view>

    <view class="form-list">
      <t-input label="变动阈值" placeholder="价格变动多少元时通知" type="number" value="{{form.threshold}}" bind:change="onInputChange" data-field="threshold" suffix="元" t-class="custom-input" />
      <t-input label="目标价格" placeholder="低于此价格时通知（可选）" type="number" value="{{form.targetPrice}}" bind:change="onInputChange" data-field="targetPrice" suffix="元" t-class="custom-input" />
      <t-input label="检查间隔" placeholder="多久检查一次价格" type="number" value="{{form.checkIntervalSec}}" bind:change="onInputChange" data-field="checkIntervalSec" suffix="秒" t-class="custom-input" />
      <t-cell title="仅降价时通知" bordered="{{false}}" t-class="custom-cell">
        <t-switch slot="note" value="{{form.notifyOnDrop}}" bind:change="onNotifyDropChange" />
      </t-cell>
    </view>
  </view>

  <!-- Notification -->
  <view class="card">
    <view class="section-title">通知方式</view>
    <view class="section-desc">可同时开启多种通知渠道，确保不错过价格变动</view>

    <view class="form-list">
      <t-cell title="小程序订阅提醒" bordered="{{false}}" t-class="custom-cell">
        <t-switch slot="note" value="{{form.subscribeEnabled}}" bind:change="onSubscribeChange" />
      </t-cell>
      <view wx:if="{{form.subscribeEnabled}}" style="padding: 0 32rpx 16rpx; font-size: 22rpx; color: #999;">
        开启后，价格变动时将通过微信服务通知提醒您（每次授权仅可发送一条提醒）
      </view>
      <view style="height: 2rpx; background: #f1f5f9; margin: 16rpx 32rpx;"></view>
      <view style="padding: 24rpx 32rpx 8rpx; font-size: 24rpx; color: #999; font-weight: 500;">PushPlus 推送（可选）</view>
      <t-textarea placeholder="请前往 PushPlus 官网获取 Token 并填入" value="{{form.pushplusToken}}" bind:change="onInputChange" data-field="pushplusToken" maxlength="{{200}}" autosize t-class="custom-textarea" />
      <t-cell title="创建后立即启用" bordered="{{false}}" t-class="custom-cell">
        <t-switch slot="note" value="{{form.active}}" bind:change="onActiveChange" />
      </t-cell>
    </view>
  </view>

  <!-- Submit -->
  <view style="margin-top: 32rpx; padding-bottom: 40rpx;">
    <t-button theme="primary" size="large" block loading="{{submitting}}" bind:tap="submit">
      {{isEdit ? '更新任务' : '创建任务'}}
    </t-button>
  </view>
</view>
