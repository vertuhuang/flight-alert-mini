<view class="page" wx:if="{{task}}">
  <!-- Task header -->
  <view class="card">
    <view style="display: flex; align-items: center; justify-content: space-between;">
      <view style="display: flex; align-items: center; gap: 12rpx;">
        <view style="font-size: 34rpx; font-weight: 800; color: #0f172a;">{{task.headerTitle}}</view>
        <view wx:if="{{!task.active}}" class="status-dot" title="已暂停"></view>
      </view>
      <t-icon name="more" size="40rpx" color="#0f172a" bindtap="onOpenActionSheet" />
    </view>

    <!-- Price -->
    <view wx:if="{{task.latestSummary && task.latestSummary.minPrice}}" style="margin-top: 12rpx; display: flex; align-items: baseline; gap: 12rpx;">
      <text style="font-size: 24rpx; color: #888888;">当前最低价</text>
      <text class="price-highlight">{{task.latestSummary.minPrice}}</text>
      <text style="font-size: 24rpx; color: #888888;">元</text>
    </view>
    <view wx:else style="margin-top: 12rpx; display: flex; align-items: baseline; gap: 12rpx;">
      <text style="font-size: 24rpx; color: #888888;">当前最低价</text>
      <text class="muted">暂无价格数据</text>
    </view>
  </view>

  <!-- Task info -->
  <view class="card">
    <view class="section-title">任务详情</view>

    <view class="detail-list">
      <view class="detail-row">
        <text class="detail-label">航程类型</text>
        <text class="detail-value">{{task.flightWay === 'Roundtrip' ? '往返' : '单程'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">出发日期</text>
        <text class="detail-value">{{task.departDatesText}}</text>
      </view>
      <view wx:if="{{task.flightWay === 'Roundtrip'}}" class="detail-row">
        <text class="detail-label">返程日期</text>
        <text class="detail-value">{{task.returnDatesText}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">变动阈值</text>
        <text class="detail-value">{{task.threshold}} 元</text>
      </view>
      <view wx:if="{{task.targetPrice}}" class="detail-row">
        <text class="detail-label">目标价格</text>
        <text class="detail-value">{{task.targetPrice}} 元</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">通知策略</text>
        <text class="detail-value">{{task.notifyOnDrop ? '仅降价' : '涨降都通知'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">通知渠道</text>
        <text class="detail-value">
          <text wx:if="{{task.subscribeEnabled}}">订阅提醒</text>
          <text wx:if="{{task.subscribeEnabled && task.pushplusToken}}"> + </text>
          <text wx:if="{{task.pushplusToken}}">PushPlus</text>
          <text wx:if="{{!task.subscribeEnabled && !task.pushplusToken}}">未配置</text>
        </text>
      </view>
      <view wx:if="{{task.subscribeEnabled}}" class="detail-row subscribe-row" bindtap="onResubscribe">
        <text class="detail-label">订阅消息授权</text>
        <text class="subscribe-action">立即获取（+{{subscribeCount}}）</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">检查间隔</text>
        <text class="detail-value">{{task.checkIntervalSec}} 秒</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">上次检查</text>
        <text class="detail-value">{{task.lastCheckedText || '尚未检查'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">下次检查</text>
        <text class="detail-value">{{task.nextCheckText || '待定'}}</text>
      </view>
      <view wx:if="{{task.lastError}}" class="detail-row">
        <text class="detail-label">最近错误</text>
        <text class="detail-value" style="color: #dc2626;">{{task.lastError}}</text>
      </view>
    </view>
  </view>

  <!-- History -->
  <view class="card">
    <view class="section-title">变价历史</view>

    <view class="history-list">
      <block wx:if="{{history.length}}">
        <view wx:for="{{history}}" wx:key="id" class="history-row">
          <view style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
            <view style="display: flex; align-items: center; gap: 16rpx;">
              <text style="font-size: 28rpx; color: #888888;">{{item.checkedAtText}}</text>
              <block wx:if="{{item.changes.length}}">
                <block wx:for="{{item.changes}}" wx:for-item="change" wx:key="key">
                  <text wx:if="{{change.type === 'rise'}}" style="font-size: 26rpx; color: #dc2626;">↑{{change.deltaAbs}}元</text>
                  <text wx:if="{{change.type === 'drop'}}" style="font-size: 26rpx; color: #16a34a;">↓{{change.deltaAbs}}元</text>
                </block>
              </block>
            </view>
            <text wx:if="{{item.summary && item.summary.minPrice}}" style="font-size: 28rpx; color: #0f172a;">{{item.summary.minPrice}} 元</text>
          </view>
        </view>
      </block>
      <view wx:else class="empty-hint">还没有历史记录</view>
    </view>
  </view>

  <t-action-sheet
    visible="{{showActionSheet}}"
    items="{{actionItems}}"
    bind:selected="onActionSheetSelect"
    bind:cancel="onActionSheetClose"
  />

  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="删除后无法恢复，确认要删除这个任务吗？"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="doDelete"
    bind:cancel="showDeleteDialog = false"
  />
</view>
