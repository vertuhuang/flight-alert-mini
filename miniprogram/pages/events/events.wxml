<view class="page">
  <view class="card">
    <view class="section-title">价格变动通知</view>
    <view class="section-desc">所有任务的价格变动事件记录</view>
  </view>

  <block wx:if="{{events.length}}">
    <view wx:for="{{events}}" wx:key="id" class="card">
      <!-- Event header -->
      <view style="display: flex; align-items: center; justify-content: space-between;">
        <view style="display: flex; align-items: center; gap: 12rpx;">
          <t-icon name="{{item.notified ? 'notification' : 'time'}}" size="40rpx" color="{{item.notified ? '#2563eb' : '#94a3b8'}}" />
          <view>
            <view style="font-size: 26rpx; color: #334155;">{{item.taskName}}</view>
            <view class="muted">{{item.createdAtText}}</view>
          </view>
        </view>
        <t-tag wx:if="{{item.notified}}" theme="primary" variant="light" size="small">已推送</t-tag>
      </view>

      <!-- Changes -->
      <view style="margin-top: 16rpx;">
        <block wx:for="{{item.changes}}" wx:for-item="change" wx:key="key">
          <view class="change-item">
            <text class="change-label">{{change.label}}</text>
            <view class="change-badge change-badge--{{change.type}}">
              {{change.type === 'rise' ? '上涨' : change.type === 'drop' ? '下降' : '首次'}}
              <text wx:if="{{change.delta !== null}}"> {{change.deltaAbs}}元</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </block>

  <view wx:else class="card">
    <t-empty icon="notification" description="暂无通知" />
  </view>
</view>
